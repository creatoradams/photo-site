# Copy to /etc/photo-site/env on the VPS (chmod 600)
PORT=8080
AUTH_SECRET=replace-with-openssl-rand-hex-32
SITE_URL=https://adamsphoto.net
DATA_DIR=/opt/photo-site/service/data
CLIENT_FILES_DIR=/data/client-files
NODE_ENV=production

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=gallery@adamsphoto.net

ADMIN_PASSWORD=choose-a-strong-password
