PORT=8080
AUTH_SECRET=generate-a-long-random-string
SITE_URL=https://adamsphoto.net
DATA_DIR=./data
CLIENT_FILES_DIR=./data/client-files
NODE_ENV=production

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=gallery@adamsphoto.net
# Where contact-form inquiries are delivered (defaults to SMTP_FROM)
CONTACT_TO=hello@adamsphoto.net

# Photographer admin dashboard at /admin
ADMIN_PASSWORD=choose-a-strong-password
