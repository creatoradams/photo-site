---
/** Abstract floating marks — original shapes, not copied from reference sites */
---
<div class="studio-shapes" aria-hidden="true">
  <svg class="studio-shape studio-shape--1" viewBox="0 0 80 80" width="80" height="80">
    <circle cx="40" cy="40" r="36" fill="none" stroke="currentColor" stroke-width="2" />
    <circle cx="40" cy="40" r="8" fill="currentColor" />
  </svg>
  <svg class="studio-shape studio-shape--2" viewBox="0 0 64 64" width="64" height="64">
    <rect x="8" y="8" width="48" height="48" rx="4" fill="none" stroke="currentColor" stroke-width="2" transform="rotate(12 32 32)" />
  </svg>
  <svg class="studio-shape studio-shape--3" viewBox="0 0 100 24" width="100" height="24">
    <path d="M0 12 Q25 0 50 12 T100 12" fill="none" stroke="currentColor" stroke-width="2" />
  </svg>
  <svg class="studio-shape studio-shape--4" viewBox="0 0 48 48" width="48" height="48">
    <polygon points="24,4 44,44 4,44" fill="none" stroke="currentColor" stroke-width="2" />
  </svg>
</div>
