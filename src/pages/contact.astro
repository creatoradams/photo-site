---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../site.config";
---
<Layout title="Contact" description="Get in touch — bookings and inquiries.">
  <div class="container studio-page" data-site-page="contact">
    <header class="studio-page-header">
      <p class="studio-hero__eyebrow">Booking</p>
      <h1 class="page-title" data-page-title>Contact</h1>
      <div class="prose" data-page-body><p>Loading…</p></div>
    </header>
    <div class="studio-contact-card hidden" data-page-extra>
      <p style="margin:0 0 0.5rem;color:var(--text-muted);font-size:0.85rem;">Email</p>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
    </div>

    <form class="studio-contact-form" data-contact-form novalidate>
      <h2 class="studio-contact-form__title">Send a message</h2>
      <div class="form-group">
        <label for="contact-name">Name</label>
        <input type="text" id="contact-name" name="name" autocomplete="name" />
      </div>
      <div class="form-group">
        <label for="contact-email">Email</label>
        <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder="you@example.com" />
      </div>
      <div class="form-group">
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows="6" required placeholder="Tell me a little about what you're looking for…"></textarea>
      </div>
      <div aria-hidden="true" style="position:absolute;left:-5000px;width:1px;height:1px;overflow:hidden;" tabindex="-1">
        <label>Leave this field empty<input type="text" name="x_field_check" tabindex="-1" autocomplete="off" /></label>
      </div>
      <p class="message error hidden" data-contact-error role="alert"></p>
      <p class="message success hidden" data-contact-success role="status"></p>
      <button type="submit" class="btn" data-contact-submit>Send message</button>
    </form>
  </div>
</Layout>

<script>
  import "../scripts/site-page.ts";
  import "../scripts/contact-form.ts";
</script>
