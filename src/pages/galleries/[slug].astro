---
/** Legacy /galleries/:slug URLs → dynamic viewer */
export function getStaticPaths() {
  return [{ params: { slug: "sample-wedding" } }];
}
const slug = Astro.params.slug;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=/galleries/view?slug=${slug}`} />
    <link rel="canonical" href={`/galleries/view?slug=${slug}`} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p><a href={`/galleries/view?slug=${slug}`}>Continue to gallery</a></p>
  </body>
</html>
